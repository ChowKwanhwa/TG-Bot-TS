generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth.js required models ──────────────────────────────

model User {
  id             String       @id @default(cuid())
  name           String?
  email          String       @unique
  emailVerified  DateTime?
  image          String?
  role           UserRole     @default(TRIAL)
  trialExpiresAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  accounts   Account[]
  sessions   AuthSession[]
  tgSessions TgSession[]
  tasks      BotTask[]

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ACTIVE
  TRIAL
  SUSPENDED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Telegram Session pool ──────────────────────────

model TgSession {
  id               String    @id @default(cuid())
  userId           String
  phone            String
  encryptedSession String    @db.Text
  sessionIv        String
  sessionTag       String
  tgUserId         BigInt?
  tgFirstName      String?
  tgLastName       String?
  tgUsername        String?
  isAlive          Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastUsedAt       DateTime?

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks BotTask[]

  @@unique([userId, phone])
  @@index([userId])
  @@index([isAlive])
  @@map("tg_sessions")
}

// ── Bot Tasks ──────────────────────────

model BotTask {
  id           String     @id @default(cuid())
  userId       String
  tgSessionId  String
  type         TaskType
  status       TaskStatus @default(PENDING)
  config       Json       // task-specific config (target, jitter, count, etc.)
  result       Json?      // task output / error info
  bullJobId    String?    // BullMQ job ID for cancellation
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  completedAt  DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tgSession TgSession @relation(fields: [tgSessionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("bot_tasks")
}

enum TaskType {
  PROFILE_MODIFY
  MESSAGE_SCRAPE
  AUTO_CHAT
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}
